{
  "name": "@skinmint/server",
  "version": "0.0.1",
  "description": "Framework-agnostic, BYO-key text-to-3D generation handler for SkinMint.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "keywords": ["text-to-3d", "meshy", "handler", "byo-key"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@skinmint/core": "workspace:*",
    "@skinmint/store": "workspace:*"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.1.1",
    "@types/node": "^20.17.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
